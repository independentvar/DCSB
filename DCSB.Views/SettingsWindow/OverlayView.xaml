<UserControl x:Class="DCSB.Views.SettingsWindow.OverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DCSB.Views.SettingsWindow"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <GroupBox Header="In-Game Overlay">
                <StackPanel>
                    <CheckBox Margin="5"
                              IsChecked="{Binding ConfigurationModel.OverlayEnabled}"
                              ToolTip="While a fullscreen or borderless-fullscreen application is in the foreground, show a bar at the top of its screen listing every sound and the keys that trigger it.">Show sound overlay over fullscreen games</CheckBox>

                    <DockPanel Margin="5,0,5,5"
                               IsEnabled="{Binding ConfigurationModel.OverlayEnabled}">
                        <Label DockPanel.Dock="Left"
                               Padding="0,0,5,0"
                               VerticalAlignment="Center">Opacity:</Label>
                        <Label DockPanel.Dock="Right"
                               MinWidth="40"
                               VerticalAlignment="Center"
                               Content="{Binding Value, ElementName=OverlayOpacitySlider}"
                               ContentStringFormat="{}{0:0}%" />
                        <Slider x:Name="OverlayOpacitySlider"
                                VerticalAlignment="Center"
                                Minimum="10"
                                Maximum="100"
                                IsSnapToTickEnabled="True"
                                TickFrequency="5"
                                IsMoveToPointEnabled="True"
                                Value="{Binding ConfigurationModel.OverlayOpacity}" />
                    </DockPanel>

                    <Button Margin="5,0,5,5"
                            HorizontalAlignment="Left"
                            Padding="10,3"
                            IsEnabled="{Binding ConfigurationModel.OverlayEnabled}"
                            Command="{Binding OpenOverlayEditCommand}"
                            ToolTip="Open a simplified preview of the overlay that you can drag to reposition and resize by its bottom-right corner.">
                        Adjust position &amp; size…
                    </Button>

                    <TextBlock Margin="5,5,5,5"
                               TextWrapping="Wrap"
                               Foreground="Gray">
                        DCSB always shows an administrator warning over a fullscreen
                        game running with elevated permissions, even when the sound
                        overlay is disabled. Restart DCSB as administrator so global
                        hotkeys can reach that game.
                    </TextBlock>

                    <TextBlock Margin="5,5,5,5"
                               TextWrapping="Wrap"
                               Foreground="Gray">
                        Note: games running in true exclusive fullscreen can bypass
                        Windows composition and hide the overlay. If the overlay does
                        not appear in your game, switch the game's display mode to
                        borderless (windowed) fullscreen.
                    </TextBlock>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
