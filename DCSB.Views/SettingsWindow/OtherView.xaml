<UserControl x:Class="DCSB.Views.SettingsWindow.OtherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DCSB.Views.SettingsWindow"
             xmlns:Utils="clr-namespace:DCSB.Utils;assembly=DCSB.Utils"
             xmlns:Controls="clr-namespace:DCSB.Controls;assembly=DCSB.Controls"
             xmlns:Converters="clr-namespace:DCSB.Converters;assembly=DCSB.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="300"
             d:DesignWidth="400">

    <UserControl.Resources>
        <Converters:VKeysToStringConverter x:Key="vKeysToStringConverter" />
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <GroupBox Header="Enable">
                <Controls:RadioButtonList SelectedValue="{Binding Enable}"
                                          SelectedValuePath="Tag">
                    <ListBoxItem Tag="{x:Static Utils:DisplayOption.Both}">Both</ListBoxItem>
                    <ListBoxItem Tag="{x:Static Utils:DisplayOption.Counters}">Only Counters</ListBoxItem>
                    <ListBoxItem Tag="{x:Static Utils:DisplayOption.Sounds}">Only Sounds</ListBoxItem>
                </Controls:RadioButtonList>
            </GroupBox>

            <GroupBox Header="Other">
                <CheckBox IsChecked="{Binding ConfigurationModel.MinimizeToTray}">Minimize to tray</CheckBox>
            </GroupBox>

            <GroupBox Header="Administrator access"
                      Visibility="{Binding NotAdministrator}">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text="DCSB works without administrator access for most games. If a game or launcher runs as administrator, Windows may prevent DCSB from receiving global hotkeys while it is focused." />
                    <Button Content="Learn more or restart as administrator…"
                            Command="{Binding OpenNotAdministratorCommand}"
                            HorizontalAlignment="Left"
                            Padding="10,3"
                            ToolTip="Explain why elevated games can block DCSB hotkeys and offer to restart DCSB as administrator." />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Setup">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text="Walk through configuring the virtual cable, audio routing and microphone, and verify that Discord will hear your sounds." />
                    <Button Content="Run setup wizard"
                            Command="{Binding OpenWizardCommand}"
                            HorizontalAlignment="Left"
                            Padding="10,3" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Backup &amp; Restore">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text="Back up your settings and key bindings to a file, or restore them from a previous backup. Restoring restarts DCSB." />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Back up..."
                                Command="{Binding BackupSettingsCommand}"
                                Padding="10,3"
                                Margin="0,0,6,0" />
                        <Button Content="Restore..."
                                Command="{Binding RestoreSettingsCommand}"
                                Padding="10,3" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
