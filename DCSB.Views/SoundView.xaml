<UserControl x:Class="DCSB.Views.SoundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Converters="clr-namespace:DCSB.Converters;assembly=DCSB.Converters"
             xmlns:Controls="clr-namespace:DCSB.Controls;assembly=DCSB.Controls"
             xmlns:Models="clr-namespace:DCSB.Models;assembly=DCSB.Models"
             xmlns:Interactivity="clr-namespace:DCSB.Interactivity;assembly=DCSB.Interactivity"
             Width="500">

    <UserControl.Resources>
        <Converters:ConcatStringsConverter x:Key="concatStringsConverter" />
        <Converters:VKeysToStringConverter x:Key="vKeysToStringConverter" />
        <Converters:AreEqualConverter x:Key="areEqualConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0">Name:</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Text="{Binding ApplicationStateModel.ModifiedSound.Name}" />

        <Label Grid.Row="1" Grid.Column="0">File/s:</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5" IsReadOnly="True" AcceptsReturn="True" MaxHeight="250" 
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Cursor="Arrow"
                 Text="{Binding ApplicationStateModel.ModifiedSound.Files, Converter={StaticResource concatStringsConverter}, ConverterParameter='&#x0a;'}"
                 Interactivity:Commands.SingleClickCommand="{Binding OpenSoundFileDialogCommand}" />
        <Button Grid.Row="1" Grid.Column="2" Margin="0,5,5,5" Width="20" Command="{Binding OpenSoundFileDialogCommand}">...</Button>

        <Label Grid.Row="2" Grid.Column="0">Key/s:</Label>
        <Controls:ShortcutBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5"
                              Text="{Binding ApplicationStateModel.ModifiedSound.Keys, Converter={StaticResource vKeysToStringConverter}}"
                              Command="{Binding BindKeysCommand}"
                              CommandParameter="{Binding ApplicationStateModel.ModifiedSound}"
                              ClearCommand="{Binding ClearBindableCommand}"
                              ClearCommandParameter="{Binding ApplicationStateModel.ModifiedSound}">
            <Controls:ShortcutBox.IsActive>
                <MultiBinding Converter="{StaticResource areEqualConverter}">
                    <Binding Path="ApplicationStateModel.ModifiedBindable" />
                    <Binding Path="ApplicationStateModel.ModifiedSound" />
                </MultiBinding>
            </Controls:ShortcutBox.IsActive>
        </Controls:ShortcutBox>

        <Label Grid.Row="3" Grid.Column="0">Volume:</Label>
        <Slider Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Maximum="100" AutoToolTipPlacement="BottomRight"
                IsMoveToPointEnabled="True" ToolTip="Change applies next time you play this sound"
                Value="{Binding ApplicationStateModel.ModifiedSound.Volume}"/>

        <Label Grid.Row="4" Grid.Column="0">Playback:</Label>
        <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
            <CheckBox Margin="5" ToolTip="Change applies next time you play this sound"
                      IsChecked="{Binding ApplicationStateModel.ModifiedSound.Loop}">Loop</CheckBox>
            <Label Margin="12,0,0,0">Press again:</Label>
            <ComboBox Margin="5" MinWidth="110"
                      SelectedValue="{Binding ApplicationStateModel.ModifiedSound.PressAgainBehavior}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Tag="{x:Static Models:PressAgainBehavior.Restart}">Restart / layer</ComboBoxItem>
                <ComboBoxItem Tag="{x:Static Models:PressAgainBehavior.Stop}">Stop</ComboBoxItem>
                <ComboBoxItem Tag="{x:Static Models:PressAgainBehavior.Pause}">Pause / resume</ComboBoxItem>
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>
