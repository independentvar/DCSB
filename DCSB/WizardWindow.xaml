<Window x:Class="DCSB.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:DCSB"
        Title="DCSB Setup"
        Width="540"
        SizeToContent="Height"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding WizardViewModel.ClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVis" />
    </Window.Resources>

    <Grid DataContext="{Binding WizardViewModel}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding StepTitle}"
                       FontSize="15"
                       FontWeight="SemiBold" />
            <Separator Margin="0,8,0,0" />
        </StackPanel>

        <!-- Step content -->
        <Grid Grid.Row="1" MinHeight="230">

            <!-- Step 1: virtual cable check -->
            <StackPanel Visibility="{Binding Step1Visibility}">
                <TextBlock TextWrapping="Wrap"
                           Text="DCSB plays sounds into a virtual audio cable so Discord and your games can hear them as if they came from your microphone. You need a virtual cable installed first." />

                <!-- cable found -->
                <Border Visibility="{Binding CableDetected, Converter={StaticResource boolToVis}}"
                        Background="#E6F4EA"
                        BorderBrush="#34A853"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Virtual cable found" FontWeight="SemiBold" Foreground="#1E7E34" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding DetectedCableName}" />
                    </StackPanel>
                </Border>

                <!-- cable missing -->
                <Border Visibility="{Binding CableMissing, Converter={StaticResource boolToVis}}"
                        Background="#FDECEA"
                        BorderBrush="#EA4335"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="No virtual cable detected" FontWeight="SemiBold" Foreground="#C5221F" />
                        <TextBlock Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Text="Install VB-Cable (free), then click Recheck - no need to restart this wizard." />
                        <Button Content="Download VB-Cable..."
                                Command="{Binding OpenCableDownloadCommand}"
                                HorizontalAlignment="Left"
                                Padding="10,3"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Button Content="Recheck"
                        Command="{Binding RecheckCommand}"
                        HorizontalAlignment="Left"
                        Padding="10,3"
                        Margin="0,12,0,0" />
            </StackPanel>

            <!-- Step 2: auto-configure -->
            <StackPanel Visibility="{Binding Step2Visibility}">
                <TextBlock TextWrapping="Wrap"
                           Text="These have been set to a known-good configuration. You can override any of them below." />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Label Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">First output (your ears):</Label>
                    <ComboBox Grid.Column="1" Grid.Row="0" Margin="3"
                              ItemsSource="{Binding AvailableOutputs}"
                              SelectedItem="{Binding PrimaryOutput}" />

                    <Label Grid.Column="0" Grid.Row="1" VerticalAlignment="Center">Second output (the cable):</Label>
                    <ComboBox Grid.Column="1" Grid.Row="1" Margin="3"
                              ItemsSource="{Binding AvailableOutputs}"
                              SelectedItem="{Binding SecondaryOutput}" />

                    <Label Grid.Column="0" Grid.Row="2" VerticalAlignment="Center">Microphone:</Label>
                    <ComboBox Grid.Column="1" Grid.Row="2" Margin="3"
                              ItemsSource="{Binding AvailableInputs}"
                              SelectedItem="{Binding MicrophoneInput}" />
                </Grid>

                <Border Background="#FEF7E0"
                        BorderBrush="#F9AB00"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,12,0,0">
                    <TextBlock TextWrapping="Wrap"
                               Text="Do NOT enable Windows' &quot;Listen to this device&quot; on your microphone. DCSB already mixes your voice into the cable - turning on Listen causes an echo." />
                </Border>
            </StackPanel>

            <!-- Step 3: verify -->
            <StackPanel Visibility="{Binding Step3Visibility}">
                <TextBlock TextWrapping="Wrap"
                           Text="Play a test tone and watch the levels. The first two are the sounds leaving each output; the last is what actually arrives at the cable's recording device - the same audio Discord will receive." />

                <Button Content="Play test sound"
                        Command="{Binding TestCommand}"
                        HorizontalAlignment="Left"
                        Padding="12,4"
                        Margin="0,12,0,0" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Label Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">First output:</Label>
                    <ProgressBar Grid.Column="1" Grid.Row="0" Margin="3" Height="10"
                                 VerticalAlignment="Center" Maximum="1"
                                 Value="{Binding PrimaryLevel, Mode=OneWay}" />

                    <Label Grid.Column="0" Grid.Row="1" VerticalAlignment="Center">Second output:</Label>
                    <ProgressBar Grid.Column="1" Grid.Row="1" Margin="3" Height="10"
                                 VerticalAlignment="Center" Maximum="1"
                                 Value="{Binding SecondaryLevel, Mode=OneWay}" />

                    <Label Grid.Column="0" Grid.Row="2" VerticalAlignment="Center">Cable output:</Label>
                    <ProgressBar Grid.Column="1" Grid.Row="2" Margin="3" Height="10"
                                 VerticalAlignment="Center" Maximum="1"
                                 Foreground="#1A73E8"
                                 Value="{Binding CableProbeLevel, Mode=OneWay}" />
                </Grid>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        CornerRadius="3"
                        BorderThickness="1"
                        Visibility="{Binding HasVerdict, Converter={StaticResource boolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FDECEA" />
                            <Setter Property="BorderBrush" Value="#EA4335" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TestPassed}" Value="True">
                                    <Setter Property="Background" Value="#E6F4EA" />
                                    <Setter Property="BorderBrush" Value="#34A853" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock TextWrapping="Wrap" Text="{Binding VerdictText}" />
                </Border>
            </StackPanel>

            <!-- Step 4: point Discord at the cable -->
            <StackPanel Visibility="{Binding Step4Visibility}">
                <TextBlock TextWrapping="Wrap"
                           Text="One last step, and it's the only one DCSB can't do for you:" />
                <Border Background="#E8F0FE"
                        BorderBrush="#1A73E8"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="12"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Text="In Discord (or your game), open the voice/microphone settings and set the Input Device to:" />
                        <TextBlock Margin="0,8,0,0"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Text="{Binding CableCaptureName}" />
                    </StackPanel>
                </Border>
                <Border Background="#F1F3F4"
                        BorderBrush="#DADCE0"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="Optional: reduce the cable's delay" />
                        <TextBlock Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Text="VB-Cable buffers your voice for a few extra milliseconds. To shrink that, open the VB-Cable Control Panel and pick a smaller value in its Latency menu (&quot;7168 smp&quot; is the default; changes apply immediately). Watch the panel's latency counter with Discord and your apps running: if it turns red or audio breaks up, the value is too small for the apps using the cable - go one step back up. &quot;3x 1024 smp&quot; is a good first try." />
                        <Button Content="Open VB-Cable Control Panel..."
                                Command="{Binding OpenCableControlPanelCommand}"
                                Visibility="{Binding HasCableControlPanel, Converter={StaticResource boolToVis}}"
                                HorizontalAlignment="Left"
                                Padding="10,3"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <TextBlock Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Opacity="0.75"
                           Text="That routes the cable's audio - your voice mixed with DCSB's sounds - into Discord. You can rerun this wizard anytime from Settings." />
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left"
                    Content="Skip setup"
                    Command="{Binding SkipCommand}"
                    Padding="10,4"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#5F6368" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Command="{Binding BackCommand}"
                        Visibility="{Binding BackVisibility}"
                        Padding="14,4"
                        Margin="0,0,8,0" />
                <Button Content="{Binding NextButtonText}"
                        Command="{Binding NextCommand}"
                        Padding="14,4"
                        MinWidth="80" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
